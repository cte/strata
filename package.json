{
  "name": "cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "check": "bun node_modules/@typescript/native-preview/bin/tsgo.js --noEmit",
    "build": "bun build ./src/tools/lintWiki.ts ./src/tools/pullGranola.ts ./src/tools/pullSlack.ts ./src/tools/pullNotion.ts --outdir=dist --target=bun",
    "lint:wiki": "bun src/tools/lintWiki.ts",
    "pull:granola": "bun src/tools/pullGranola.ts",
    "pull:slack": "bun src/tools/pullSlack.ts",
    "pull:notion": "bun src/tools/pullNotion.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "beta"
  }
}
