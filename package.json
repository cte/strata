{
  "name": "cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "check": "bun node_modules/@typescript/native-preview/bin/tsgo.js --noEmit",
    "check:workspaces": "bun run --filter '*' check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:check": "biome check .",
    "test": "bun test",
    "build": "bun build ./packages/ingest/src/lintWiki.ts ./packages/ingest/src/pullGranola.ts ./packages/ingest/src/pullSlack.ts ./packages/ingest/src/pullNotion.ts ./packages/cli/src/index.ts --outdir=dist --target=bun",
    "cortex": "bun packages/cli/src/index.ts",
    "lint:wiki": "bun packages/ingest/src/lintWiki.ts",
    "pull:granola": "bun packages/ingest/src/pullGranola.ts",
    "pull:slack": "bun packages/ingest/src/pullSlack.ts",
    "pull:notion": "bun packages/ingest/src/pullNotion.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "beta"
  }
}
