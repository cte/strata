# Copy to .env and fill only the connectors you use. .env is gitignored.

# Granola API path. Do not use undocumented endpoints; provide the documented
# endpoint URL for listing meetings if Granola API access is available.
GRANOLA_API_TOKEN=
GRANOLA_MEETINGS_URL=
GRANOLA_TRANSCRIPT_URL_TEMPLATE=

# Slack direct fetch path for src/tools/pullSlack.ts.
SLACK_BOT_TOKEN=
SLACK_WORKSPACE_URL=

# Notion direct fetch path for src/tools/pullNotion.ts.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28
