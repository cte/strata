# Copy to .env and fill only the connectors you use. .env is gitignored.
# Runtime scripts use dotenvx automatically, so encrypted .env values work with
# `bun run strata`, `bun run web:api`, and the pull scripts.

# Agent model path for `bun run strata query`.
# openai-codex uses ChatGPT OAuth via `bun run strata auth login openai-codex`.
# openai-compatible uses STRATA_API_KEY/OPENAI_API_KEY and defaults to https://api.openai.com/v1.
STRATA_PROVIDER=openai-codex
STRATA_API_KEY=
STRATA_MODEL=
STRATA_BASE_URL=
STRATA_CODEX_BASE_URL=

# Local web control-plane unlock token. If unset, `bun run web:api`
# creates a local token at .strata/web-auth-token and prints that path.
STRATA_WEB_TOKEN=
# Set STRATA_WEB_AUTH=off only for explicitly local/dev test runs.
STRATA_WEB_AUTH=

# Granola API path. Do not use undocumented endpoints; provide the documented
# endpoint URL for listing meetings if Granola API access is available.
GRANOLA_API_TOKEN=
GRANOLA_MEETINGS_URL=
GRANOLA_TRANSCRIPT_URL_TEMPLATE=

# Slack connector path. Prefer SLACK_USER_TOKEN for mirroring conversations the
# installing user can access. SLACK_APP_TOKEN is required for Socket Mode.
SLACK_USER_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_WORKSPACE_URL=

# Notion direct fetch path for src/tools/pullNotion.ts.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28
