{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "biome.json",
      "package.json",
      "tsconfig.json",
      "src/**/*.ts",
      "scripts/**/*.ts",
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "apps/**/package.json",
      "apps/**/tsconfig*.json",
      "packages/**/*.ts",
      "packages/**/package.json",
      "packages/**/tsconfig.json",
      "!dist",
      "!node_modules",
      "!.strata",
      "!.cortex",
      "!raw"
    ]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100
    }
  },
  "linter": {
    "enabled": false
  }
}
